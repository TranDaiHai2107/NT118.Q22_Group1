<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Healthcare"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".activity.OnboardingActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".activity.LoginActivity" />
        <activity android:name=".activity.RegisterActivity" />
        <activity android:name=".activity.ForgotPasswordActivity" />
        <activity android:name=".activity.ResetPasswordActivity" />
        <activity android:name=".activity.HomeActivity" />
        <activity android:name=".activity.SearchActivity" />
        <activity android:name=".activity.DoctorDetailActivity" />
        <activity android:name=".activity.HospitalDetailActivity" />
        <activity android:name=".activity.BookingActivity" />
        <activity android:name=".activity.PaymentActivity" />
        <activity android:name=".activity.ConfirmationActivity" />
        <activity android:name=".activity.AppointmentsActivity" />
        <activity android:name=".activity.CheckInActivity" />
        <activity android:name=".activity.MedicalRecordsActivity" />
        <activity android:name=".activity.NotificationsActivity" />
        <activity android:name=".activity.InsuranceActivity" />
        <activity android:name=".activity.ProfileActivity" />
    </application>
</manifest>
