<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Healthcare" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/pastel_blue</item>
        <item name="colorPrimaryDark">@color/pastel_blue_dark</item>
        <item name="colorAccent">@color/pastel_lavender</item>
        <item name="colorSecondary">@color/pastel_mint</item>
        <item name="android:colorBackground">@color/healthcare_white</item>
        <item name="android:textColorPrimary">@color/healthcare_dark</item>
        <item name="android:textColorSecondary">@color/healthcare_muted</item>
        <item name="android:statusBarColor">@color/healthcare_white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="RoundedButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/pastel_blue</item>
        <item name="android:textColor">@color/healthcare_dark</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <style name="RoundedButtonMint" parent="RoundedButton">
        <item name="backgroundTint">@color/pastel_mint</item>
    </style>

    <style name="RoundedButtonLavender" parent="RoundedButton">
        <item name="backgroundTint">@color/pastel_lavender</item>
    </style>

    <style name="RoundedOutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/pastel_blue</item>
        <item name="android:textColor">@color/pastel_blue</item>
    </style>

    <style name="RoundedCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <style name="RoundedInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/transparent</item>
        <item name="boxBackgroundColor">@color/healthcare_gray</item>
    </style>

    <style name="TabStyle" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/pastel_blue</item>
        <item name="tabSelectedTextColor">@color/healthcare_dark</item>
        <item name="tabTextColor">@color/healthcare_muted</item>
    </style>
</resources>
